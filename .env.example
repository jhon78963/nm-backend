APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:generate_your_own_key_here
APP_DEBUG=false
APP_TIMEZONE=America/Lima
APP_URL=http://localhost
FRONTEND_URL=http://localhost:4200

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Local / staging: debug. Producción: warning (evita ruido y stack traces en logs).
LOG_LEVEL=debug
# LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=database_name
DB_USERNAME=username
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=null

# =============================================================================
# DEPLOY SECURITY — producción (checklist: docs/DEPLOY-SECURITY.md)
# =============================================================================
# Cookies Sanctum / sesión SPA. En HTTPS siempre SESSION_SECURE_COOKIE=true.
# SPA y API en subdominios distintos (ej. adm.* + api.*):
#   SESSION_DOMAIN=.tudominio.com
#   SESSION_SAME_SITE=none          # obligatorio cross-subdomain; requiere Secure
#   SESSION_SECURE_COOKIE=true
#   SESSION_ENCRYPT=true
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
# SESSION_SAME_SITE=lax
# SESSION_DOMAIN=.novedadesmaritex.net.pe
# SESSION_SAME_SITE=none
#
# Headers HTTP (HSTS, X-Frame-Options, etc.) los añade el middleware SecurityHeaders
# en rutas api/*. Nginx puede duplicarlos o reforzarlos en el reverse proxy.

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=

# Microservicio Node (uploader-service) — usado por vouchers de caja y productos
UPLOADER_URL=http://127.0.0.1:3050
UPLOADER_API_KEY=your_uploader_api_key
# Alias legacy (opcional si no defines UPLOADER_*)
ZG_URL=https://api.example.com
ZG_TOKEN=your_token_here

# APIs.net.pe — consultas DNI/RUC (SUNAT/RENIEC)
SUNAT_TOKEN=

# Catálogo público GET /api/prod/ecommerce?store=TOKEN (legacy Multikart / storefront externo)
# Token por almacén en BD (warehouses.catalog_public_token) o fallback monotienda:
ECOMMERCE_WAREHOUSE_ID=
ECOMMERCE_PUBLIC_STORE_TOKEN=

# URL base del servidor de imágenes del catálogo ecommerce (sin barra final)
IMAGE_SERVER_URL=http://localhost:8001

# URL pública de archivos S3 (fallback: AWS_URL)
S3_URL=

VITE_APP_NAME="${APP_NAME}"

# Sin barra final. Obligatorio en local si el SPA corre en :4200
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Dominios SPA con cookies Sanctum (sin https://, separados por coma).
# Local: valores por defecto en config/sanctum.php. Producción: definir explícitamente.
# SANCTUM_STATEFUL_DOMAINS=adm.tudominio.com,app.tudominio.com

# Contraseña de usuarios demo del seeder (vendedora, superadmin)
SEEDER_DEFAULT_PASSWORD=password123

# === SUNAT / Greenter (Facturación Electrónica) ===
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  QUÉ VA EN .env                    │  QUÉ VA EN tenant_settings (BD)    │
# ├────────────────────────────────────┼────────────────────────────────────┤
# │  SUNAT_MODE, SOL_USER, SOL_PASS    │  RUC, razón social, nombre comercial│
# │  SUNAT_CERT_PATH / CERT_CONTENT      │  Dirección, teléfono, email, web    │
# │  SUNAT_RUC + dirección (XML UBL)     │  Redes sociales (JSONB)             │
# │  SUNAT_TOKEN (consulta DNI/RUC)      │  Logo URL, nota al pie del ticket   │
# └────────────────────────────────────┴────────────────────────────────────┘
#
# Los campos de emisor abajo se usan para FIRMAR y ENVIAR el XML a SUNAT (Greenter).
# El ticket POS prioriza tenant_settings; si el tenant no tiene settings, usa estos
# valores como fallback. Configura cada tenant en Admin → Tenants → Editar.
#
# Mode: beta (sandbox) | homologacion | produccion
SUNAT_MODE=beta

# Emisor fiscal — cabecera del XML UBL (obligatorio para emitir comprobantes)
SUNAT_RUC=20000000001
SUNAT_RAZON_SOCIAL="EMPRESA DE PRUEBA SAC"
SUNAT_NOMBRE_COMERCIAL="EMPRESA DE PRUEBA"

# Credenciales SOL (en beta: MODDATOS / MODDATOS)
SUNAT_SOL_USER=MODDATOS
SUNAT_SOL_PASS=MODDATOS

# Certificado digital (.pem = clave privada + certificado público concatenados)
# Opción A — ruta absoluta (desarrollo local):
SUNAT_CERT_PATH=
# Opción B — contenido base64 (producción / CI): base64 -i cert.pem | tr -d '\n'
# SUNAT_CERT_CONTENT=

# Dirección fiscal del emisor en el XML (ubigeo catálogo INEI)
SUNAT_UBIGEO=150101
SUNAT_DEPARTAMENTO=LIMA
SUNAT_PROVINCIA=LIMA
SUNAT_DISTRITO=LIMA
SUNAT_DIRECCION="DIR FISCAL EMISOR"
SUNAT_CODIGO_PAIS=PE
